@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using MyUmbracoProject.Controller
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Umbraco.Cms.Core.Services.IMemberService MemberService

@{
    var isLoggedIn = User.Identity != null && User.Identity.IsAuthenticated;

    string memberName = string.Empty;
    if (isLoggedIn)
    {
        var member = MemberService.GetByEmail(User.Identity!.Name ?? "");
        memberName = member?.Name ?? User.Identity!.Name ?? "User";
    }
}

<header class="site-header">
    <div class="site-header-inner">
        <h1 class="site-title">Level Up Umbraco Skills</h1>

        <nav>
            <ul class="nav-list">
                <li><a class="nav-link" href="/#info">Info</a></li>
                <li><a class="nav-link" href="/#about">About</a></li>
                <li><a class="nav-link" href="/#contact">Contact</a></li>

                @if (!isLoggedIn)
                {
                    <li><a class="nav-link" href="/register">Register</a></li>
                    <li><a class="nav-link" href="/login">Login</a></li>
                }
            </ul>
        </nav>

        <div style="display:flex; align-items:center; gap:1rem;">

            @if (isLoggedIn)
            {
                <div style="display:flex; align-items:center; gap:0.75rem;">
                    <div style="
                        width: 38px; height: 38px;
                        border-radius: 50%;
                        background: #2563eb; color: white;
                        display: flex; align-items: center;
                        justify-content: center;
                        font-weight: 700; font-size: 1rem;
                        text-transform: uppercase;">
                        @(memberName.Length > 0 ? memberName.Substring(0,1) : "U")
                    </div>
                    <span style="color:white; font-weight:600; font-size:0.95rem;">
                        @memberName
                    </span>
                </div>

                @using (Html.BeginUmbracoForm<AuthSurfaceController>("HandleLogout"))
                {
                    <button type="submit" style="
                        padding: 0.5rem 1rem;
                        background: rgba(239,68,68,0.85);
                        color: white; border: none;
                        border-radius: 0.75rem;
                        cursor: pointer; font-weight: 600;
                        font-size: 0.9rem;">
                        Logout
                    </button>
                }
            }
            else
            {
                <select class="language-switcher">
                    <option>English</option>
                </select>
            }

        </div>
    </div>
</header>