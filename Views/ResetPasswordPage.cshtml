@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using MyUmbracoProject.Controller
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var token = Context.Request.Query["token"].ToString();
    var email = Context.Request.Query["email"].ToString();
}

<div class="page-content">
    <div class="form-card">
        <h2>Reset Password</h2>
        <p style="color:#6b7280; text-align:center; margin-bottom:1.5rem;">
            Enter your new password below.
        </p>

        @await Html.PartialAsync("Partials/_AlertMessage")

        @if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(email))
        {
            <div style="color:red; text-align:center; padding:1rem;">
                Invalid or expired reset link.
                <br/>
                <a href="/forgot-password">Request a new one</a>
            </div>
        }
        else
        {
            @using (Html.BeginUmbracoForm<ForgotPasswordSurfaceController>
                ("HandleResetPassword"))
            {
                <input type="hidden" name="Token" value="@token" />
                <input type="hidden" name="Email" value="@email" />

                <div class="form-group">
                    <label for="NewPassword">New Password</label>
                    <input id="NewPassword" name="NewPassword"
                           class="form-field" type="password"
                           placeholder="Enter new password" />
                    @Html.ValidationMessage("NewPassword",
                        new { style = "color:red; font-size:0.85rem;" })
                </div>

                <div class="form-group">
                    <label for="ConfirmPassword">Confirm Password</label>
                    <input id="ConfirmPassword" name="ConfirmPassword"
                           class="form-field" type="password"
                           placeholder="Confirm new password" />
                    @Html.ValidationMessage("ConfirmPassword",
                        new { style = "color:red; font-size:0.85rem;" })
                </div>

                <button type="submit" class="form-button">
                    Reset Password
                </button>
            }
        }

        <p class="form-help"><a href="/login">Back to Login</a></p>
    </div>
</div>