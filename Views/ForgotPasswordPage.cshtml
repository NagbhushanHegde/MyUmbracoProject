@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using MyUmbracoProject.Controller
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="form-card">
        <h2>Forgot Password</h2>
        <p style="color:#6b7280; text-align:center; margin-bottom:1.5rem;">
            Enter your email and we'll send you a reset link.
        </p>

        @await Html.PartialAsync("Partials/_AlertMessage")

        @using (Html.BeginUmbracoForm<ForgotPasswordSurfaceController>
            ("HandleForgotPassword"))
        {
            <div class="form-group">
                <label for="Email">Email</label>
                <input id="Email" name="Email" class="form-field"
                       type="email" placeholder="Enter your email" />
                @Html.ValidationMessage("Email",
                    new { style = "color:red; font-size:0.85rem;" })
            </div>

            <button type="submit" class="form-button">
                Send Reset Link
            </button>
        }

        <p class="form-help">
            Remember your password? <a href="/login">Login</a>
        </p>
    </div>
</div>