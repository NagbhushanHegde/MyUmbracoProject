@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using MyUmbracoProject.Models
@using MyUmbracoProject.Controller
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="form-card">
        <h2>Login</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="color:red; margin-bottom:1rem;">
                @Html.ValidationSummary(false)
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="color:green; margin-bottom:1rem;">@TempData["SuccessMessage"]</div>
        }

        @using (Html.BeginUmbracoForm<AuthSurfaceController>("HandleLogin"))
        {
          

            <div class="form-group">
                <label for="Email">Email</label>
                <input id="Email" name="Email" class="form-field" type="email" placeholder="Enter your email" />
                @Html.ValidationMessage("Email", new { style = "color:red; font-size:0.85rem;" })
            </div>

            <div class="form-group">
                <label for="Password">Password</label>
                <input id="Password" name="Password" class="form-field" type="password" placeholder="Enter your password" />
                @Html.ValidationMessage("Password", new { style = "color:red; font-size:0.85rem;" })
            </div>

            <button type="submit" class="form-button">Login</button>

        }
            <p style="text-align:right; margin-top:0.5rem;">
    <a href="/forgot-password" style="font-size:0.9rem; color:#2563eb;">
        Forgot password?
    </a>
</p>
        <p class="form-help">Don't have an account? <a href="/register">Register</a></p>
    </div>
</div>